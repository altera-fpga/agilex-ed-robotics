<PROJECT name="top">
  <DEVKIT>AGX_5E_Modular_Devkit</DEVKIT>
  <FAMILY>Agilex 5</FAMILY>
  <DEVICE>A5ED065BB32AE4S</DEVICE>
  <VERSION>26.1</VERSION>
  <PIP>1</PIP>
  <VID_OUT_RATE>p30</VID_OUT_RATE>
  <VID_OUT_BPS>10</VID_OUT_BPS>
  <VID_OUT_PIP>2</VID_OUT_PIP>
  <MULTI_SENSOR>0</MULTI_SENSOR>
  <EXP_FUSION_EN>0</EXP_FUSION_EN>
  <EN_DEBUG>1</EN_DEBUG>

  <SUBSYSTEM type="board" name="board_subsystem">
    <USER_LED_TO_AVMM_EN>0</USER_LED_TO_AVMM_EN>
    <USER_PB_TO_AVMM_EN>0</USER_PB_TO_AVMM_EN>
    <USER_DIP_SW_TO_AVMM_EN>0</USER_DIP_SW_TO_AVMM_EN>
    <DEVICE_READY_EN>1</DEVICE_READY_EN>
  </SUBSYSTEM>

  <SUBSYSTEM type="clock" name="clock_subsystem">
    <NUM_GEN_CLOCKS>5</NUM_GEN_CLOCKS>
    <GEN_CLK0_NAME>clk_0</GEN_CLK0_NAME>
    <GEN_CLK0_FREQ>297</GEN_CLK0_FREQ>
    <GEN_CLK1_NAME>clk_1</GEN_CLK1_NAME>
    <GEN_CLK1_FREQ>148.5</GEN_CLK1_FREQ>
    <GEN_CLK2_NAME>clk_2</GEN_CLK2_NAME>
    <GEN_CLK2_FREQ>200.0</GEN_CLK2_FREQ>
    <GEN_CLK3_NAME>clk_3</GEN_CLK3_NAME>
    <GEN_CLK3_FREQ>16.0</GEN_CLK3_FREQ>
    <GEN_CLK4_NAME>clk_4</GEN_CLK4_NAME>
    <GEN_CLK4_FREQ>50.0</GEN_CLK4_FREQ>
    <RESET_MIN_LENGTH>3000</RESET_MIN_LENGTH>
    <EXPORT_TO_TOP>1</EXPORT_TO_TOP>
  </SUBSYSTEM>

  <SUBSYSTEM type="hps" name="hps_subsystem">
    <FPGA_EMIF_ENABLED>1</FPGA_EMIF_ENABLED>
    <FPGA_EMIF_ASYNC>1</FPGA_EMIF_ASYNC>
    <FPGA_EMIF_ASYNC_CLK_HZ>200000000</FPGA_EMIF_ASYNC_CLK_HZ>
    <FPGA_EMIF_WINDOW_BASE_ADDRESS>0x20000000</FPGA_EMIF_WINDOW_BASE_ADDRESS>
    <FPGA_EMIF_WINDOW_CTRL_BASE_ADDRESS>0x04000000</FPGA_EMIF_WINDOW_CTRL_BASE_ADDRESS>
    <FPGA_EMIF_HOST_ADDR_WIDTH>33</FPGA_EMIF_HOST_ADDR_WIDTH>
    <FPGA_EMIF_AGENT_ADDR_WIDTH>25</FPGA_EMIF_AGENT_ADDR_WIDTH>
    <H2F_EXPORT>LIGHT</H2F_EXPORT>
    <HPS_INIT>HPS FIRST</HPS_INIT>
    <MSGDMA_AGENT>emif</MSGDMA_AGENT>
    <MSGDMA_AGENT_ADDR_WIDTH>33</MSGDMA_AGENT_ADDR_WIDTH>
    <HPS_AXI_CLK>200000000</HPS_AXI_CLK>
    <H2F_ADDRESS_WIDTH>34</H2F_ADDRESS_WIDTH>
    <F2SDRAM_ADDR_WIDTH>36</F2SDRAM_ADDR_WIDTH>
  </SUBSYSTEM>

  <SUBSYSTEM type="cpu" name="niosv_subsystem">
    <CPU_SUBSYSTEM_TYPE>niosv</CPU_SUBSYSTEM_TYPE>
    <APPLICATION_DIR>../custom_user_subsystems/isp_subsystems/software_rob/src/.</APPLICATION_DIR>
    <APPLICATION_DIR>../custom_user_subsystems/isp_subsystems/software_rob/cfg/cfg_sensor/cfg.h</APPLICATION_DIR>
    <BSP_SETTINGS_FILE>../custom_user_subsystems/isp_subsystems/software_rob/settings.bsp</BSP_SETTINGS_FILE>
    <CUSTOM_CMAKEFILE>1</CUSTOM_CMAKEFILE>
    <MEMORY_SIZE>0x40000</MEMORY_SIZE>
    <TIMER_TYPE>full</TIMER_TYPE>
    <TIMER_PERIOD>1</TIMER_PERIOD>
    <TIMER_UNITS>USEC</TIMER_UNITS>
    <JTAG_UART_EN>1</JTAG_UART_EN>
    <CPU_TIMER_EN>1</CPU_TIMER_EN>
  </SUBSYSTEM>

  <SUBSYSTEM type="user" name="mipi_in_subsystem" script="../custom_user_subsystems/isp_subsystems/mipi_4k_in_subsystem/framos_imx678/mipi_in_framos_imx678_create.tcl">
    <CAM_I2C_MASTER_IRQ_PRIORITY>5</CAM_I2C_MASTER_IRQ_PRIORITY>
    <CAM_I2C_MASTER_IRQ_HOST>niosv_subsystem</CAM_I2C_MASTER_IRQ_HOST>
    <CAM_I2C_BOARD_EN>1</CAM_I2C_BOARD_EN>
    <CAM_I2C_BOARD_IRQ_PRIORITY>6</CAM_I2C_BOARD_IRQ_PRIORITY>
    <CAM_I2C_BOARD_IRQ_HOST>niosv_subsystem</CAM_I2C_BOARD_IRQ_HOST>
    <EN_SNOOP_MONITOR>0</EN_SNOOP_MONITOR>
    <AVMM_HOST>
      <NAME>niosv_subsystem</NAME>
    </AVMM_HOST>
  </SUBSYSTEM>
  <SUBSYSTEM type="user" name="isp_in_subsystem" script="../custom_user_subsystems/isp_subsystems/isp_4k_in_subsystem/isp_4k_in_create.tcl">
    <AVMM_HOST>
      <NAME>niosv_subsystem</NAME>
    </AVMM_HOST>
  </SUBSYSTEM>

  <SUBSYSTEM type="user" name="isp_lite_subsystem" script="../custom_user_subsystems/isp_subsystems/isp_4k_subsystem/isp_4k_create.tcl">
    <PIP>1</PIP>
    <VID_OUT_RATE>p60</VID_OUT_RATE>
    <VID_OUT_BPS>10</VID_OUT_BPS>
    <EN_DEBUG>1</EN_DEBUG>
    <AVMM_HOST>
      <NAME>niosv_subsystem</NAME>
    </AVMM_HOST>
  </SUBSYSTEM>

  <SUBSYSTEM type="user" name="isp_rob_subsystem" script="../custom_user_subsystems/isp_subsystems/isp_4k_rob_subsystem/isp_4k_rob_create.tcl">
    <EN_HPS_HOST>1</EN_HPS_HOST>
    <LRES_VFW_IRQ_PRIORITY>0</LRES_VFW_IRQ_PRIORITY>
    <LRES_VFW_IRQ_HOST>hps_subsystem</LRES_VFW_IRQ_HOST>
    <LRES_VFW_GS_IRQ_PRIORITY>1</LRES_VFW_GS_IRQ_PRIORITY>
    <LRES_VFW_GS_IRQ_HOST>hps_subsystem</LRES_VFW_GS_IRQ_HOST>
    <EN_FRAME_RD>0</EN_FRAME_RD>
    <LRES_VFR_IRQ_PRIORITY>2</LRES_VFR_IRQ_PRIORITY>
    <LRES_VFR_IRQ_HOST>hps_subsystem</LRES_VFR_IRQ_HOST>
    <EN_GS_OUTPUT>1</EN_GS_OUTPUT>
    <ARUCO_MK_EN>0</ARUCO_MK_EN>
    <FPGA_EMIF_ASYNC>1</FPGA_EMIF_ASYNC>
    <FPGA_EMIF_ASYNC_CLK_HZ>200000000</FPGA_EMIF_ASYNC_CLK_HZ>
    <AVMM_HOST>
      <NAME>niosv_subsystem</NAME>
    </AVMM_HOST>
    <AVMM_HOST_2>
      <NAME>hps_subsystem</NAME>
    </AVMM_HOST_2>
  </SUBSYSTEM>

  <SUBSYSTEM type="emif" name="emif">
    <PORT>BANK_2B</PORT>
    <ASYNC_CLK>1</ASYNC_CLK>
    <ASYNC_CLK_HZ>200000000</ASYNC_CLK_HZ>
    <AVMM_EN>1</AVMM_EN>
  </SUBSYSTEM>

  <SUBSYSTEM type="user" name="isp_lite_out_subsystem" script="../custom_user_subsystems/isp_subsystems/isp_4k_out_subsystem/isp_4k_out_create.tcl">
    <PIP>1</PIP>
    <VID_OUT_BPS>10</VID_OUT_BPS>
    <EXTRA_MIX_INPUTS_XPRT>1</EXTRA_MIX_INPUTS_XPRT>
    <EN_DEBUG>1</EN_DEBUG>
    <FPGA_EMIF_ASYNC>1</FPGA_EMIF_ASYNC>
    <FPGA_EMIF_ASYNC_CLK_HZ>200000000</FPGA_EMIF_ASYNC_CLK_HZ>
    <AVMM_HOST>
      <NAME>niosv_subsystem</NAME>
    </AVMM_HOST>
  </SUBSYSTEM>

  <SUBSYSTEM type="emif" name ="emif_2">
    <PORT>BANK_3B</PORT>
    <ASYNC_CLK>1</ASYNC_CLK>
    <ASYNC_CLK_HZ>200000000</ASYNC_CLK_HZ>
    <AVMM_EN>1</AVMM_EN>
  </SUBSYSTEM>

  <SUBSYSTEM type="user" name="dp_tx" script="../custom_user_subsystems/isp_subsystems/dp_tx_subsystem/dp_tx_create.tcl">
    <I2C_MASTER_IRQ_PRIORITY>2</I2C_MASTER_IRQ_PRIORITY>
    <I2C_MASTER_IRQ_HOST>niosv_subsystem</I2C_MASTER_IRQ_HOST>
    <I2C_BOARD_IRQ_PRIORITY>3</I2C_BOARD_IRQ_PRIORITY>
    <I2C_BOARD_IRQ_HOST>niosv_subsystem</I2C_BOARD_IRQ_HOST>
    <DP_IRQ_PRIORITY>4</DP_IRQ_PRIORITY>
    <DP_IRQ_HOST>niosv_subsystem</DP_IRQ_HOST>
    <AVMM_HOST>
      <NAME>niosv_subsystem</NAME>
    </AVMM_HOST>
  </SUBSYSTEM>

</PROJECT>
